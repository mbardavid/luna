"""DecisionEnvelope v1 for Quant -> PMM runner handoff."""

from __future__ import annotations

import json
from dataclasses import asdict, dataclass, field
from datetime import datetime, timezone
from decimal import Decimal
from pathlib import Path
from typing import Any, Literal


def _decimal(value: Any, *, field_name: str) -> Decimal:
    try:
        return Decimal(str(value))
    except Exception as exc:  # pragma: no cover - defensive
        raise ValueError(f"invalid decimal for {field_name}: {value!r}") from exc


def _float(value: Any, *, field_name: str) -> float:
    try:
        return float(value)
    except Exception as exc:  # pragma: no cover - defensive
        raise ValueError(f"invalid float for {field_name}: {value!r}") from exc


def _int(value: Any, *, field_name: str) -> int:
    try:
        return int(value)
    except Exception as exc:  # pragma: no cover - defensive
        raise ValueError(f"invalid int for {field_name}: {value!r}") from exc


def _bool(value: Any, *, field_name: str) -> bool:
    if isinstance(value, bool):
        return value
    if isinstance(value, str):
        lowered = value.strip().lower()
        if lowered in {"1", "true", "yes", "y", "on"}:
            return True
        if lowered in {"0", "false", "no", "n", "off"}:
            return False
    raise ValueError(f"invalid bool for {field_name}: {value!r}")


def _parse_dt(value: str | datetime, *, field_name: str) -> datetime:
    if isinstance(value, datetime):
        dt = value
    else:
        dt = datetime.fromisoformat(str(value).replace("Z", "+00:00"))
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    return dt.astimezone(timezone.utc)


def _require_non_empty(value: Any, *, field_name: str) -> str:
    text = str(value or "").strip()
    if not text:
        raise ValueError(f"missing {field_name}")
    return text


def _market_type(value: Any) -> str:
    text = str(value or "OTHER").strip().upper()
    if not text:
        return "OTHER"
    return text


@dataclass(slots=True)
class CapitalPolicy:
    total_capital_usdc: Decimal
    rewards_capital_usdc: Decimal
    directional_capital_usdc: Decimal
    reserve_capital_usdc: Decimal

    @classmethod
    def from_dict(cls, raw: dict[str, Any]) -> "CapitalPolicy":
        item = cls(
            total_capital_usdc=_decimal(raw.get("total_capital_usdc"), field_name="total_capital_usdc"),
            rewards_capital_usdc=_decimal(raw.get("rewards_capital_usdc"), field_name="rewards_capital_usdc"),
            directional_capital_usdc=_decimal(raw.get("directional_capital_usdc"), field_name="directional_capital_usdc"),
            reserve_capital_usdc=_decimal(raw.get("reserve_capital_usdc"), field_name="reserve_capital_usdc"),
        )
        if item.total_capital_usdc <= 0:
            raise ValueError("capital_policy.total_capital_usdc must be > 0")
        if item.rewards_capital_usdc < 0 or item.directional_capital_usdc < 0 or item.reserve_capital_usdc < 0:
            raise ValueError("capital_policy values must be >= 0")
        allocated = item.rewards_capital_usdc + item.directional_capital_usdc + item.reserve_capital_usdc
        if allocated > item.total_capital_usdc + Decimal("0.000001"):
            raise ValueError("capital_policy allocated capital exceeds total_capital_usdc")
        return item

    def to_dict(self) -> dict[str, Any]:
        return {
            "total_capital_usdc": str(self.total_capital_usdc),
            "rewards_capital_usdc": str(self.rewards_capital_usdc),
            "directional_capital_usdc": str(self.directional_capital_usdc),
            "reserve_capital_usdc": str(self.reserve_capital_usdc),
        }


@dataclass(slots=True)
class ModeAllocations:
    rewards_enabled: bool = True
    directional_enabled: bool = False
    directional_max_pct: int = 10
    priority_order: list[str] = field(
        default_factory=lambda: ["rewards_farming", "event_driven"]
    )

    @classmethod
    def from_dict(cls, raw: dict[str, Any] | None) -> "ModeAllocations":
        raw = raw or {}
        item = cls(
            rewards_enabled=_bool(raw.get("rewards_enabled", True), field_name="rewards_enabled"),
            directional_enabled=_bool(raw.get("directional_enabled", False), field_name="directional_enabled"),
            directional_max_pct=_int(raw.get("directional_max_pct", 10), field_name="directional_max_pct"),
            priority_order=[str(v) for v in raw.get("priority_order", ["rewards_farming", "event_driven"])],
        )
        if item.directional_max_pct < 0 or item.directional_max_pct > 100:
            raise ValueError("mode_allocations.directional_max_pct must be between 0 and 100")
        if item.priority_order != ["rewards_farming", "event_driven"]:
            raise ValueError("mode_allocations.priority_order must be ['rewards_farming', 'event_driven']")
        return item

    def to_dict(self) -> dict[str, Any]:
        return asdict(self)


