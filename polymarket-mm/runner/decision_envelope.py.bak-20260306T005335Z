@dataclass(slots=True)
class EventDrivenMarketDecision:
    mode: Literal["event_driven"]
    market_id: str
    condition_id: str
    token_id_yes: str
    token_id_no: str
    side: Literal["YES", "NO"]
    entry_price_limit: Decimal
    model_probability: float
    market_implied_probability: float
    edge_bps: float
    confidence: float
    stake_usdc: Decimal
    max_slippage_bps: int
    ttl_seconds: int
    stop_rule: str
    take_profit_rule: str
    source_evidence_ids: list[str] = field(default_factory=list)
    disable_reason: str = ""
    description: str = ""
    market_type: str = "OTHER"
    tick_size: Decimal = Decimal("0.01")
    min_order_size: Decimal = Decimal("5")
    neg_risk: bool = False

    @classmethod
    def from_dict(cls, raw: dict[str, Any]) -> "EventDrivenMarketDecision":
        side = str(raw.get("side", "YES")).strip().upper()
        if side not in {"YES", "NO"}:
            raise ValueError("event_driven.side must be YES or NO")
        item = cls(
            mode="event_driven",
            market_id=_require_non_empty(raw.get("market_id"), field_name="market_id"),
            condition_id=_require_non_empty(raw.get("condition_id"), field_name="condition_id"),
            token_id_yes=_require_non_empty(raw.get("token_id_yes"), field_name="token_id_yes"),
            token_id_no=_require_non_empty(raw.get("token_id_no"), field_name="token_id_no"),
            side=side,
            entry_price_limit=_decimal(raw.get("entry_price_limit"), field_name="entry_price_limit"),
            model_probability=_float(raw.get("model_probability"), field_name="model_probability"),
            market_implied_probability=_float(raw.get("market_implied_probability"), field_name="market_implied_probability"),
            edge_bps=_float(raw.get("edge_bps"), field_name="edge_bps"),
            confidence=_float(raw.get("confidence"), field_name="confidence"),
            stake_usdc=_decimal(raw.get("stake_usdc"), field_name="stake_usdc"),
            max_slippage_bps=_int(raw.get("max_slippage_bps"), field_name="max_slippage_bps"),
            ttl_seconds=_int(raw.get("ttl_seconds"), field_name="ttl_seconds"),
            stop_rule=str(raw.get("stop_rule", "") or ""),
            take_profit_rule=str(raw.get("take_profit_rule", "") or ""),
            source_evidence_ids=[str(v) for v in raw.get("source_evidence_ids", [])],
            disable_reason=str(raw.get("disable_reason", "") or ""),
            description=str(raw.get("description", "") or ""),
            market_type=_market_type(raw.get("market_type", "OTHER")),
            tick_size=_decimal(raw.get("tick_size", "0.01"), field_name="tick_size"),
            min_order_size=_decimal(raw.get("min_order_size", "5"), field_name="min_order_size"),
            neg_risk=bool(raw.get("neg_risk", False)),
        )
        if item.confidence < 0 or item.confidence > 1:
            raise ValueError("event_driven.confidence must be between 0 and 1")
        if item.stake_usdc <= 0:
            raise ValueError("event_driven.stake_usdc must be > 0")
        return item

    @property
    def enabled(self) -> bool:
        return not self.disable_reason

    def to_dict(self) -> dict[str, Any]:
        return {
            "mode": self.mode,
            "market_id": self.market_id,
            "condition_id": self.condition_id,
            "token_id_yes": self.token_id_yes,
            "token_id_no": self.token_id_no,
            "side": self.side,
            "entry_price_limit": str(self.entry_price_limit),
            "model_probability": self.model_probability,
            "market_implied_probability": self.market_implied_probability,
            "edge_bps": self.edge_bps,
            "confidence": self.confidence,
            "stake_usdc": str(self.stake_usdc),
            "max_slippage_bps": self.max_slippage_bps,
            "ttl_seconds": self.ttl_seconds,
            "stop_rule": self.stop_rule,
            "take_profit_rule": self.take_profit_rule,
            "source_evidence_ids": list(self.source_evidence_ids),
            "disable_reason": self.disable_reason,
            "description": self.description,
            "market_type": self.market_type,
            "tick_size": str(self.tick_size),
            "min_order_size": str(self.min_order_size),
            "neg_risk": self.neg_risk,
        }


DecisionMarket = RewardMarketDecision | EventDrivenMarketDecision


@dataclass(slots=True)
class DecisionEnvelope:
    decision_id: str
    generated_at: datetime
    expires_at: datetime
    transport_policy: Literal["direct_preferred", "direct_only", "proxy_fallback"]
    capital_policy: CapitalPolicy
    mode_allocations: ModeAllocations
    markets: list[DecisionMarket]
    risk_limits: RiskLimits = field(default_factory=RiskLimits)
    kill_switches: KillSwitches = field(default_factory=KillSwitches)
    metadata: dict[str, Any] = field(default_factory=dict)

    @classmethod
    def from_dict(cls, raw: dict[str, Any]) -> "DecisionEnvelope":
        decision_id = _require_non_empty(raw.get("decision_id"), field_name="decision_id")
        generated_at = _parse_dt(raw.get("generated_at"), field_name="generated_at")
        expires_at = _parse_dt(raw.get("expires_at"), field_name="expires_at")
        transport_policy = str(raw.get("transport_policy", "direct_preferred")).strip()
        if transport_policy not in {"direct_preferred", "direct_only", "proxy_fallback"}:
            raise ValueError("transport_policy must be direct_preferred, direct_only or proxy_fallback")
        capital_policy = CapitalPolicy.from_dict(raw.get("capital_policy") or {})
        mode_allocations = ModeAllocations.from_dict(raw.get("mode_allocations"))
        markets: list[DecisionMarket] = []
        for market in raw.get("markets", []):
            mode = str(market.get("mode", "rewards_farming")).strip()
            if mode == "rewards_farming":
                markets.append(RewardMarketDecision.from_dict(market))
            elif mode == "event_driven":
                markets.append(EventDrivenMarketDecision.from_dict(market))
            else:
                raise ValueError(f"unsupported market mode: {mode}")

        if not markets:
            raise ValueError("decision envelope must contain at least one market")

        item = cls(
            decision_id=decision_id,
            generated_at=generated_at,
            expires_at=expires_at,
            transport_policy=transport_policy,
            capital_policy=capital_policy,
            mode_allocations=mode_allocations,
            markets=markets,
            risk_limits=RiskLimits.from_dict(raw.get("risk_limits")),
            kill_switches=KillSwitches.from_dict(raw.get("kill_switches")),
            metadata=dict(raw.get("metadata") or {}),
        )
        if item.generated_at >= item.expires_at:
            raise ValueError("generated_at must be before expires_at")
        directional_pct = (
            item.capital_policy.directional_capital_usdc / item.capital_policy.total_capital_usdc * Decimal("100")
        )
        if directional_pct > Decimal(str(item.mode_allocations.directional_max_pct)) + Decimal("0.000001"):
            raise ValueError("directional_capital_usdc exceeds directional_max_pct cap")
        return item

    @classmethod
    def load(cls, path: str | Path) -> "DecisionEnvelope":
        with open(path) as handle:
            raw = json.load(handle)
        return cls.from_dict(raw)

    @property
    def rewards_markets(self) -> list[RewardMarketDecision]:
        return [m for m in self.markets if isinstance(m, RewardMarketDecision)]

    @property
    def directional_markets(self) -> list[EventDrivenMarketDecision]:
        return [m for m in self.markets if isinstance(m, EventDrivenMarketDecision)]

    def is_expired(self, now: datetime | None = None) -> bool:
        current = now or datetime.now(timezone.utc)
        if current.tzinfo is None:
            current = current.replace(tzinfo=timezone.utc)
        return current.astimezone(timezone.utc) >= self.expires_at

    def require_live_ready(self, now: datetime | None = None) -> None:
        if self.is_expired(now):
            raise ValueError(f"decision envelope {self.decision_id} is expired")
        if not self.mode_allocations.rewards_enabled and not self.mode_allocations.directional_enabled:
            raise ValueError("decision envelope disables all modes")
        if not any(m.enabled for m in self.markets):
            raise ValueError("decision envelope has no enabled markets")

    def enabled_markets(self, mode: str | None = None) -> list[DecisionMarket]:
        items: list[DecisionMarket] = [m for m in self.markets if m.enabled]
        if mode is None:
            return items
        return [m for m in items if m.mode == mode]

    def to_dict(self) -> dict[str, Any]:
        return {
            "decision_id": self.decision_id,
            "generated_at": self.generated_at.isoformat(),
            "expires_at": self.expires_at.isoformat(),
            "transport_policy": self.transport_policy,
            "capital_policy": self.capital_policy.to_dict(),
            "mode_allocations": self.mode_allocations.to_dict(),
            "markets": [m.to_dict() for m in self.markets],
            "risk_limits": self.risk_limits.to_dict(),
            "kill_switches": self.kill_switches.to_dict(),
            "metadata": self.metadata,
        }

    def save(self, path: str | Path) -> None:
        payload = self.to_dict()
        output = Path(path)
        output.parent.mkdir(parents=True, exist_ok=True)
        tmp = output.with_suffix(output.suffix + ".tmp")
        with open(tmp, "w") as handle:
            json.dump(payload, handle, indent=2, sort_keys=False)
        tmp.replace(output)


def envelope_to_json(envelope: DecisionEnvelope) -> str:
    return json.dumps(envelope.to_dict(), indent=2, sort_keys=False)
