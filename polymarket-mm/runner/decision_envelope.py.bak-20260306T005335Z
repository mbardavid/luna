            reward_max_spread_cents=_decimal(raw.get("reward_max_spread_cents", 0), field_name="reward_max_spread_cents"),
            expected_reward_yield_bps_day=_float(raw.get("expected_reward_yield_bps_day", 0.0), field_name="expected_reward_yield_bps_day"),
            expected_fill_rate_pct=_float(raw.get("expected_fill_rate_pct", 0.0), field_name="expected_fill_rate_pct"),
            max_inventory_per_side=_decimal(raw.get("max_inventory_per_side"), field_name="max_inventory_per_side"),
            order_size=_decimal(raw.get("order_size"), field_name="order_size"),
            half_spread_bps=_int(raw.get("half_spread_bps"), field_name="half_spread_bps"),
            min_quote_lifetime_s=_float(raw.get("min_quote_lifetime_s", 30.0), field_name="min_quote_lifetime_s"),
